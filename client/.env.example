# Copy to .env to configure the client.

# Multiplayer server URL (defaults to http://localhost:3001 when unset).
# VITE_SERVER_URL=https://aetherbeasts-server.onrender.com

# Solana RPC the client uses to submit premium-summon ($AETHER) payments.
# Defaults to the public mainnet endpoint, which rate-limits hard — use a paid
# RPC (Helius / QuickNode / Triton) in production, and a devnet RPC while testing
# against a devnet token.
# VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com
