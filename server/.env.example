# Copy to .env and adjust. Every value is optional — the server runs fully
# in-memory with sensible defaults if nothing is set.

# HTTP / Socket.IO port
PORT=3001

# Allowed CORS origin for the Vite dev client (use * for any during dev)
CLIENT_ORIGIN=http://localhost:5181

# Optional Postgres connection string. If set, player records are persisted to a
# `players` table (jsonb). If unset, the server keeps state in memory only.
# DATABASE_URL=postgres://user:pass@localhost:5432/aetherbeasts

# --- Solana / $AETHER (read-only balance display) ---------------------------
# Wallet sign-in is verified locally via ed25519 and needs no RPC.
SOLANA_CLUSTER=devnet

# TOKEN_MODE controls the read-only $AETHER balance shown in the HUD:
#   sim     -> a stable fake balance derived from the wallet (no RPC, default)
#   devnet  -> real SPL balance read from devnet for AETHER_MINT
#   mainnet -> real SPL balance read from mainnet for AETHER_MINT
TOKEN_MODE=sim
# The $AETHER SPL token mint (leave empty in sim mode; required for devnet/mainnet)
AETHER_MINT=
# Override the RPC endpoint if desired
# SOLANA_RPC=https://api.devnet.solana.com

# --- on-chain $AETHER gacha (premium summons paid in the token) --------------
# DISABLED until BOTH a mint (above) and a treasury are set. When live, premium
# summons are priced in USD and converted to $AETHER at the live token price.
#
# The wallet that premium summons pay into (your project treasury):
# TREASURY_ADDRESS=
# Mint decimals (pump.fun tokens are 6):
AETHER_DECIMALS=6
# USD price per pull (the token amount is derived from the live price):
SUMMON_USD_1=1.5
SUMMON_USD_10=13.5
# Fallback $AETHER/USD if the price feed is down — set near your launch price so
# an outage never charges an absurd token amount:
AETHER_PRICE_FLOOR_USD=0.00005
# Sane band for a live price tick; a value outside it is treated as a bad feed:
AETHER_PRICE_MIN_USD=0.000000001
AETHER_PRICE_MAX_USD=1000
# How long a price quote stays valid before the client must re-quote (ms). Also
# the window in which a paid-but-dropped summon can be re-submitted to redeem:
QUOTE_TTL_MS=300000

# NOTE: set DATABASE_URL (above) for production — it makes used payment signatures
# durable (replay-safe across restarts + multiple instances). Without a DB the
# single-use ledger is in-memory only.
